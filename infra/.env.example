# Infra/Docker Compose example. Copy to `infra/.env` to override defaults.
# Production-grade values live in your secrets manager; never commit real ones.

HEARTSCAN_ENV=staging
HEARTSCAN_API_KEY=change-me-in-production
# Production: list explicit origins (https://app.example.com, etc.).
HEARTSCAN_CORS_ORIGINS=https://app.example.com
HEARTSCAN_ALLOW_LEGACY_API_KEY=false
HEARTSCAN_MAX_UPLOAD_BYTES=10485760
HEARTSCAN_PIPELINE_VERSION=0.1.0
# Mount or COPY the checkpoint into the image and point this variable to it.
HEARTSCAN_MODEL_PATH=
HEARTSCAN_JWT_SECRET_KEY=generate-with-secrets-token_urlsafe-48
HEARTSCAN_DATABASE_URL=postgresql+psycopg2://heartscan:heartscan@postgres:5432/heartscan
HEARTSCAN_BETA_DAILY_ANALYSIS_QUOTA=100
POSTGRES_PASSWORD=replace-me-strong-password
HEARTSCAN_SENTRY_DSN=
