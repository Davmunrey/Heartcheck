# Next.js — copy to .env.local. Never commit real secrets.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Dashboard → Settings → API: Project URL + anon public
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ML API (FastAPI on Fly.io or local)
ML_API_URL=http://127.0.0.1:8000
ML_API_INTERNAL_TOKEN=

# Clerk webhooks (optional)
CLERK_WEBHOOK_SECRET=

# Automation (optional) — scripts/bootstrap_clerk_supabase.sh & ensure_supabase_clerk_third_party.py
# Personal Access Token: https://supabase.com/dashboard/account/tokens (needs auth:write)
# SUPABASE_ACCESS_TOKEN=
# Override if URL does not end in .supabase.co:
# SUPABASE_PROJECT_REF=
# Override Clerk issuer if you do not use NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY:
# CLERK_ISSUER_URL=https://YOUR_INSTANCE.clerk.accounts.dev
