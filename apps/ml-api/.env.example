# HeartScan backend — example environment variables.
# Copy to `apps/ml-api/.env` for local dev. Never commit real secrets.

# ---- Authentication & rate limiting -----------------------------------------
# Static API key used by the legacy X-API-Key path. Keep ONLY in dev or staging.
HEARTSCAN_API_KEY=dev-key-change-me
# Production hardening: set to false to require Bearer JWT on /api/v1/analyze.
HEARTSCAN_ALLOW_LEGACY_API_KEY=true
# Comma-separated list. Use exact origins in production (no "*").
HEARTSCAN_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://127.0.0.1:5174
# Maximum image upload size in bytes (10 MiB default).
HEARTSCAN_MAX_UPLOAD_BYTES=10485760

# ---- Database ----------------------------------------------------------------
HEARTSCAN_DATABASE_URL=sqlite:///./data/heartscan.db
# Postgres (Docker Compose) example:
# HEARTSCAN_DATABASE_URL=postgresql+psycopg2://heartscan:heartscan_dev@localhost:5432/heartscan

# ---- JWT (legacy email/password auth) --------------------------------------
# REQUIRED in production if HEARTSCAN_AUTH_LEGACY_ENABLED=true: long random secret.
HEARTSCAN_JWT_SECRET_KEY=replace-with-long-random-secret-min-32-chars
HEARTSCAN_JWT_ALGORITHM=HS256
HEARTSCAN_JWT_EXPIRE_MINUTES=10080
# Set false in production when using Clerk-only auth.
HEARTSCAN_AUTH_LEGACY_ENABLED=true

# ---- Clerk (Bearer on /analyze) ---------------------------------------------
# When set, Bearer tokens are verified as Clerk JWTs (JWKS).
# HEARTSCAN_CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
# HEARTSCAN_CLERK_ISSUER=https://YOUR_INSTANCE.clerk.accounts.dev
# Shared secret with Next.js server actions (X-Internal-Token).
# HEARTSCAN_ML_INTERNAL_TOKEN=


# ---- Quotas / abuse control --------------------------------------------------
HEARTSCAN_BETA_DAILY_ANALYSIS_QUOTA=100

# ---- ML model ----------------------------------------------------------------
# Absolute or repo-relative path to a CNN1D checkpoint (.pt). When unset or
# missing, the API falls back to the heuristic classifier and returns
# `model_version` indicating an untrained baseline.
# HEARTSCAN_MODEL_PATH=apps/ml-api/weights/cnn1d_best.pt
# Only enable if you must support PyTorch < 2.4 AND the checkpoint comes from a
# trusted, signed source. Otherwise leave unset to keep weights_only=True.
# HEARTSCAN_ALLOW_UNSAFE_TORCH_LOAD=false

# ---- Observability -----------------------------------------------------------
HEARTSCAN_SENTRY_DSN=
HEARTSCAN_ENV=development
