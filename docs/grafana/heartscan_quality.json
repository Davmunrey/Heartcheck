{
  "title": "HeartScan — Model quality",
  "uid": "heartscan-quality",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "tags": ["heartscan", "quality"],
  "time": {"from": "now-24h", "to": "now"},
  "refresh": "1m",
  "panels": [
    {
      "type": "stat",
      "title": "Status share (last 1h)",
      "id": 1,
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (status) (rate(heartscan_analyze_status_total[1h])) / clamp_min(sum(rate(heartscan_analyze_status_total[1h])), 0.001)",
          "legendFormat": "{{status}}"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "timeseries",
      "title": "Predicted class distribution",
      "id": 2,
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "sum by (class_label) (rate(heartscan_analyze_class_total[5m])) / clamp_min(sum(rate(heartscan_analyze_class_total[5m])), 0.001)",
          "legendFormat": "{{class_label}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Calibrated confidence — median, p10, p90",
      "id": 3,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {"expr": "histogram_quantile(0.5,  sum(rate(heartscan_analyze_confidence_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.1,  sum(rate(heartscan_analyze_confidence_bucket[5m])) by (le))", "legendFormat": "p10"},
        {"expr": "histogram_quantile(0.9,  sum(rate(heartscan_analyze_confidence_bucket[5m])) by (le))", "legendFormat": "p90"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Extraction quality — median, p10, p90",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum(rate(heartscan_analyze_extraction_quality_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.1, sum(rate(heartscan_analyze_extraction_quality_bucket[5m])) by (le))", "legendFormat": "p10"},
        {"expr": "histogram_quantile(0.9, sum(rate(heartscan_analyze_extraction_quality_bucket[5m])) by (le))", "legendFormat": "p90"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Non-reportable reasons (rate)",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [
        {"expr": "sum by (reason) (rate(heartscan_analyze_non_reportable_total[5m]))", "legendFormat": "{{reason}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Conformal prediction-set size — mean",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [
        {"expr": "sum(rate(heartscan_analyze_prediction_set_size_sum[5m])) / clamp_min(sum(rate(heartscan_analyze_prediction_set_size_count[5m])), 0.001)", "legendFormat": "mean"}
      ]
    },
    {
      "type": "stat",
      "title": "Grid-calibrated share",
      "id": 7,
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 22},
      "targets": [
        {"expr": "sum(rate(heartscan_analyze_grid_calibrated_total{basis=\"GRID_CALIBRATED\"}[1h])) / clamp_min(sum(rate(heartscan_analyze_grid_calibrated_total[1h])), 0.001)", "legendFormat": "grid"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 (s)",
      "id": 8,
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 22},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum(rate(heartscan_analyze_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(heartscan_analyze_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}
      ]
    }
  ]
}
